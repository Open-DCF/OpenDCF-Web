# 1. Redirect all HTTP to HTTPS
server {
    listen 80;
    server_name opendcf.io www.opendcf.io opendcf.org www.opendcf.org;
    return 301 https://$host$request_uri;
}

# 2. HTTPS for .io domain
server {
    listen 443 ssl;
    server_name opendcf.io www.opendcf.io;

    ssl_certificate     /etc/nginx/ssl/io-cert.crt;
    ssl_certificate_key /etc/nginx/ssl/io-cert.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    root /var/www/opendcf-web;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}

# 3. HTTPS for .org domain
server {
    listen 443 ssl;
    server_name opendcf.org www.opendcf.org;

    ssl_certificate     /etc/nginx/ssl/org-cert.crt;
    ssl_certificate_key /etc/nginx/ssl/org-cert.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    root /var/www/opendcf-web;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}